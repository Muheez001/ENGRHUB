rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════
    // Helper Functions
    // ══════════════════════════════════════════════
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if a user belongs to the same university + department + year
    // Used for voting eligibility
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ══════════════════════════════════════════════
    // Users — own profile only
    // ══════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Updates limited to safe fields only (no role escalation)
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'isAdmin', 'trustScore']);

      // Progress subcollection — user's own data
      match /progress/{courseId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ══════════════════════════════════════════════
    // Departments — read-only, writes via Admin SDK
    // ══════════════════════════════════════════════
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /years/{yearId} {
        allow read: if isAuthenticated();
        allow write: if false;

        match /sessions/{sessionId} {
          allow read: if isAuthenticated();
          allow write: if false;
        }
      }
    }

    // ══════════════════════════════════════════════
    // Courses — read-only, writes via Admin SDK
    // ══════════════════════════════════════════════
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /topics/{topicId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ══════════════════════════════════════════════
    // Exercises — read questions only, answers are EXCLUDED
    // Answer validation happens via checkAnswer Cloud Function
    // ══════════════════════════════════════════════
    match /exercises/{exerciseId} {
      // Allow reading exercise documents, but the answer/solution
      // fields are stored in a separate subcollection that clients
      // cannot access. This is enforced by collection structure,
      // not field-level rules (which Firestore doesn't support).
      allow read: if isAuthenticated();
      allow write: if false;

      // Answer keys — COMPLETELY locked from clients
      // Only the checkAnswer Cloud Function reads these via Admin SDK
      match /answerKey/{keyId} {
        allow read, write: if false;
      }
    }

    // ══════════════════════════════════════════════
    // Pending Syllabi — upload + voting flow
    // ══════════════════════════════════════════════
    match /pendingSyllabi/{uploadId} {
      // CREATE: Authenticated user can submit a new pending syllabus
      // Must set themselves as uploader and status as 'pending'
      allow create: if isAuthenticated()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
            'universityId', 'deptId', 'yearNumber', 'uploadedBy', 'status'
        ]);

      // READ: Only students from the same university + department can see
      // pending syllabi (or the uploader themselves)
      allow read: if isAuthenticated()
        && (
          resource.data.uploadedBy == request.auth.uid
          || (
            getUserProfile().university == resource.data.universityId
            && getUserProfile().department == resource.data.deptId
          )
        );

      // UPDATE + DELETE: Only via Cloud Functions (Admin SDK)
      // Voting is done via the castVote Cloud Function
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════
    // Votes — separate collection for vote auditing
    // Written by castVote Cloud Function only
    // ══════════════════════════════════════════════
    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ══════════════════════════════════════════════
    // Scrape Status — read-only for clients
    // ══════════════════════════════════════════════
    match /scrapeStatus/{statusId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
